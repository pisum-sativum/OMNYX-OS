# Supabase (optional — enables realtime threat event sync)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Proxy — run: npm run server
# Emulator: use http://10.0.2.2:3001
# Real device: use your Mac's LAN IP, e.g. http://192.168.x.x:3001
# Find your IP: run `ipconfig getifaddr en0` on your Mac
EXPO_PUBLIC_AI_PROXY_URL=http://10.0.2.2:3001

# Server-side only (never prefix with EXPO_PUBLIC_)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
