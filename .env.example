# Supabase (optional — enables realtime threat event sync)
# Create a project at https://supabase.com
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Proxy URL — run backend locally: cd backend && npm run dev
# DO NOT put AI provider API keys here — they belong in backend/.env only
EXPO_PUBLIC_AI_PROXY_URL=http://localhost:3001
